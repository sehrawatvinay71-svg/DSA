#include<bits/stdc++.h>
using namespace std;
#define int long long
int n;

vector<int> arr;

int dp[100001][2];

int rec(int i, int nexts){
    //pruning
    //basecase
    if(i==n){
        return 0;
    }
    //cache check
    if(dp[i][nexts]!=-1) return dp[i][nexts];
    //transition
    int ans = -1e18;
    int val = arr[i];
    if(nexts == 1){
        val=-val;
    }
    if(i+1<n) ans = max(ans, val*(-1)+rec(i+1,1));
    ans = max(ans,val+rec(i+1,0));
    return dp[i][nexts] = ans;
    //save and return
}

signed main(){
    cin>>n;
    arr.resize(n);
    memset(dp,-1,sizeof(dp));
    for(int i=0;i<n;i++){
        cin>>arr[i];
    }
    cout<<rec(0,0);
}
