#include<bits/stdc++.h>
using namespace std;
#define int long long

struct node{
    int sum;
    node(){
        sum=0;
    }
};
int n,q;
vector<int> arr;
node segtree[800800];


node merge(node a,node b){
    node ans;
    ans.sum = a.sum+b.sum;
    return ans;
}

void build(int idx,int l,int r){
    if(l==r){
        segtree[idx].sum = 0;
        return;
    }
    int mid = (l+r)/2;
    build(2*idx,l,mid);
    build(2*idx+1,mid+1,r);
    segtree[idx] = merge(segtree[2*idx],segtree[2*idx+1]);
}

void update(int idx,int l,int r,int pos,int val){
    if(pos<l||pos>r){
        return;
    }
    if(l==r){
        segtree[idx].sum +=val;
        return;
    }
    int mid = (l+r)/2;
    update(2*idx,l,mid,pos,val);
    update(2*idx+1,mid+1,r,pos,val);

    segtree[idx] = merge(segtree[2*idx],segtree[2*idx+1]);
}

node query(int idx,int l,int r,int lq,int rq){
    if(lq>r||l>rq){
        return node();
    }
    if(lq<=l&&r<=rq){
        return segtree[idx];
    }
    int mid = (l+r)/2;
    return merge(query(2*idx,l,mid,lq,rq),query(2*idx+1,mid+1,r,lq,rq));
}


signed main(){
    cin>>n>>q;
    arr.resize(n);
    for(int i=0;i<n;i++){
        cin>>arr[i];       
    }
    build(1,0,n-1);
    // update(1,0,n-1,1,1);
    // update(1,0,n-1,4,-1);
    // for(int i=1;i<4*n;i++){
    //     cout<<i<<" "<<segtree[i].sum<<endl;
    // }
    while(q--){
        int x;
        cin>>x;
        if(x==1){
            int a,b,u;
            cin>>a>>b>>u;
            a--;b--;
            update(1,0,n-1,a,u);
            update(1,0,n-1,b+1,-u);
        }else{
            int k;
            cin>>k;
            k--;
            node ans = query(1,0,n-1,0,k) ;
            cout<<ans.sum+arr[k]<<endl;
        }
    }
}
