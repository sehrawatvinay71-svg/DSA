class Solution {
public:
    int removeDuplicates(vector<int>& nums) {
        int j = 0;

        for(int i = 0; i < nums.size(); i++) {

            // Pehle 2 elements hamesha rakh sakte hain
            // Uske baad check karo current number,
            // 2 position pehle wale number ke equal na ho
            if(j < 2 || nums[i] != nums[j - 2]) {
                nums[j] = nums[i];
                j++;
            }
        }

        return j;
    }
};
