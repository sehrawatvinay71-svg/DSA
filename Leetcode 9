class Solution {
public:
    bool isPalindrome(int x) {
        string s = to_string(x);
        if(x<0){
            return false;
        }
        int l = 0;
        int r = s.length()-1;
        while(l<r){
            if(s[l]!=s[r]){
                return false;
            }
            l++;
            r--;
        }
        return true;
    }
};
