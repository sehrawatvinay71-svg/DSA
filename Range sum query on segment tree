#include<bits/stdc++.h>
using namespace std;
#define int long long
vector<int> arr;
int n,q;
int seg_tree[800800];

void build(int idx,int l,int r){
    if(l==r){
        seg_tree[idx]=arr[l];
        return;
    }
    int mid = (l+r)/2;
    build(2*idx,l,mid);
    build((2*idx)+1,mid+1,r);
    seg_tree[idx] = seg_tree[2*idx] + seg_tree[2*idx+1];
}

void update(int idx,int l,int r,int pos,int new_val){
    if(l==r){
        seg_tree[idx]=new_val;
        arr[pos]=new_val;
        return;
    }
    int mid = (l+r)/2;
    if(pos<=mid){
        update(2*idx,l,mid,pos,new_val);
    }else{
        update(2*idx+1,mid+1,r,pos,new_val);
    }
    seg_tree[idx] = seg_tree[2*idx]+seg_tree[2*idx+1];
}

int query(int idx,int l,int r,int lq,int rq){
    if(lq>r||rq<l) return 0;
    if(lq<=l&&rq>=r){
        return seg_tree[idx];
    }
    int mid = (l+r)/2;
    return query(2*idx,l,mid,lq,rq) + query(2*idx+1,mid+1,r,lq,rq);
}

signed main(){
    cin>>n>>q;
    arr.resize(n+1);
    for(int i=0;i<n;i++){
        cin>>arr[i];
    }
    build(1,0,n-1);
    for(int i=0;i<q;i++){
        int d;cin>>d;
        if(d==1){
            int a,b;
            cin>>a>>b;
            a--;
            update(1,0,n-1,a,b);
        }
        else{
            int a,b;

            cin>>a>>b;
            a--;
            b--;

            cout<<query(1,0,n-1,a,b)<<endl;
        }
    }
}
