#include<bits/stdc++.h>
using namespace std;
#define int long long
int n,q;
int arr[200200];

struct node{
    int xors;
    node(){
        xors = 0;
    }
};

node seg_tree[8000800];

node make_node(int x){
    node ans;
    ans.xors = x;
    return ans;
}

node merge(node a,node b){
    node ans;
    ans.xors = a.xors ^ b.xors;
    return ans;
}

void build(int idx, int l,int r){
    if(l==r){
        seg_tree[idx] = make_node(arr[l]);
        return;
    }
    int mid = (l+r)/2;
    build(2*idx,l,mid);
    build(2*idx+1,mid+1,r);
    seg_tree[idx] = merge(seg_tree[2*idx],seg_tree[2*idx+1]);
}

node query(int idx,int l,int r,int lq,int rq){
    if(r<lq||rq<l){
        return node();
    }
    if(l>=lq&&r<=rq){
        return seg_tree[idx];
    }
    int mid = (l+r)/2;
    return merge(query(2*idx,l,mid,lq,rq),query(2*idx+1,mid+1,r,lq,rq));
}

signed main(){
    cin>>n>>q;
    for(int i=1;i<=n;i++){
        cin>>arr[i];
    }
    build(1,1,n);
    // for(int i=1;i<4*n;i++){
    //     cout<<"i : "<<i<<" open : "<<seg_tree[i].open<<" close : "<<seg_tree[i].close<<" all : "<<seg_tree[i].all<<endl;
    // }
    while(q--){
        int a,b;
        cin>>a>>b;
        node ans = query(1,1,n,a,b);
        cout<<ans.xors<<endl;
    }

}
