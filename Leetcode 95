class Solution {
public:

    vector<TreeNode*> rec(int l, int r){
        //pruning

        //basecase
        if(l > r){
            return {NULL};
        }

        //cachecheck

        //transition
        vector<TreeNode*> ans;

        for(int i = l; i <= r; i++){
            // i is current root

            vector<TreeNode*> leftpart = rec(l, i - 1);
            vector<TreeNode*> rightpart = rec(i + 1, r);

            for(auto leftnode : leftpart){
                for(auto rightnode : rightpart){

                    TreeNode* root = new TreeNode(i);

                    root->left = leftnode;
                    root->right = rightnode;

                    ans.push_back(root);
                }
            }
        }

        //save and return
        return ans;
    }

    vector<TreeNode*> generateTrees(int n) {
        return rec(1, n);
    }
};
