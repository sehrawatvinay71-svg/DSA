#include<bits/stdc++.h>
using namespace std;
#define int long long
int n,q;

int arr[200200];

struct node{
    int sum;
    bool islazy;
    int lazyset;
    bool islazyadd;
    int lazyadd;
    node(){
        sum = 0;
        islazy = false;
        lazyset = 0;
        islazyadd = false;
        lazyadd = 0;
    }
};

node seg_tree[800800];

node merge(node a,node b){
    node ans;
    ans.sum = a.sum+b.sum;
    return ans;
}

void push(int idx, int l,int r){
    if(l==r) return;
    if(!seg_tree[idx].islazy&&!seg_tree[idx].islazyadd) return;

    int mid = (l+r)/2;

    if(seg_tree[idx].islazy){
        seg_tree[2*idx].sum = (mid-l+1)*seg_tree[idx].lazyset;
        seg_tree[2*idx+1].sum = (r-mid)*seg_tree[idx].lazyset;

        seg_tree[2*idx].islazy = true;
        seg_tree[2*idx+1].islazy = true;

        seg_tree[2*idx].lazyset = seg_tree[idx].lazyset;
        seg_tree[2*idx+1].lazyset = seg_tree[idx].lazyset;

        seg_tree[2*idx].islazyadd = false;
        seg_tree[2*idx+1].islazyadd = false;

        seg_tree[2*idx].lazyadd = 0;
        seg_tree[2*idx+1].lazyadd = 0;
    }
    if(seg_tree[idx].islazyadd){
        seg_tree[2*idx].sum += (mid-l+1)*seg_tree[idx].lazyadd;
        seg_tree[2*idx+1].sum += (r-mid)*seg_tree[idx].lazyadd;

        if(seg_tree[2*idx].islazy){
            seg_tree[2*idx].lazyset += seg_tree[idx].lazyadd;
        }else{
            seg_tree[2*idx].islazyadd = true;
            seg_tree[2*idx].lazyadd += seg_tree[idx].lazyadd;
        }
        if(seg_tree[2*idx+1].islazy){
            seg_tree[2*idx+1].lazyset += seg_tree[idx].lazyadd;
        }else{
            seg_tree[2*idx+1].islazyadd = true;
            seg_tree[2*idx+1].lazyadd += seg_tree[idx].lazyadd;
        }
    }

    seg_tree[idx].islazy = false;
    seg_tree[idx].islazyadd = false;
    seg_tree[idx].lazyadd = 0;
    seg_tree[idx].lazyset = 0;
}

void build(int idx,int l,int r){
    if(l==r){
        seg_tree[idx].sum = arr[l];
        return;
    }
    int mid = (l+r)/2;
    build(2*idx,l,mid);
    build(2*idx+1,mid+1,r);
    seg_tree[idx] = merge(seg_tree[2*idx],seg_tree[2*idx+1]);
}

void updateset(int idx,int l,int r,int lq,int rq,int val){
    if(l>rq||lq>r){
        return;
    }
    if(l>=lq&&r<=rq){
        seg_tree[idx].sum = (r-l+1)*val;

        seg_tree[idx].islazy = true;
        seg_tree[idx].lazyset = val;

        seg_tree[idx].islazyadd = false;
        seg_tree[idx].lazyadd =0;
        return;
    }
    push(idx,l,r);
    int mid = (l+r)/2;
    updateset(2*idx,l,mid,lq,rq,val);
    updateset(2*idx+1,mid+1,r,lq,rq,val);

    seg_tree[idx] = merge(seg_tree[2*idx],seg_tree[2*idx+1]);
}

void updatesum(int idx,int l,int r,int lq,int rq,int val){
    if(l>rq||lq>r){
        return;
    }
    if(l>=lq&&r<=rq){
        seg_tree[idx].sum += (r-l+1)*val;

        if(seg_tree[idx].islazy == true){
            seg_tree[idx].lazyset += val;
        }else{
            seg_tree[idx].islazyadd = true;
            seg_tree[idx].lazyadd+=val;
        }
        return;
    }
    push(idx,l,r);
    int mid = (l+r)/2;
    updatesum(2*idx,l,mid,lq,rq,val);
    updatesum(2*idx+1,mid+1,r,lq,rq,val);

    seg_tree[idx] = merge(seg_tree[2*idx],seg_tree[2*idx+1]);
}

node query(int idx,int l,int r,int lq, int rq){
    if(lq>r||l>rq){
        return node();
    }
    if(l>=lq&&r<=rq){
        return seg_tree[idx];
    }
    push(idx,l,r);
    int mid = (l+r)/2;
    return merge(query(2*idx,l,mid,lq,rq),query(2*idx+1,mid+1,r,lq,rq));

}

signed main(){
    cin>>n>>q;
    for(int i=1;i<=n;i++){
        cin>>arr[i];
    }
    build(1,1,n);
    for(int i=0;i<q;i++){
        int a;
        cin>>a;
        if(a==1){
            int x,y,z;
            cin>>x>>y>>z;
            updatesum(1,1,n,x,y,z);
        }else if(a==2){
            int x,y,z;
            cin>>x>>y>>z;
            updateset(1,1,n,x,y,z);
        }else{
            int x,y;
            cin>>x>>y;
            node ans = query(1,1,n,x,y);
            cout<<ans.sum<<endl;
        }
    }
}
