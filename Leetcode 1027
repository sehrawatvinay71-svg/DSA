class Solution {
public:
    int longestArithSeqLength(vector<int>& nums) {
        int ans = 0;
        int dp[1001][1001];
        memset(dp,0,sizeof(dp));
        for(int i=0;i<nums.size();i++){
            for(int j=0;j<i;j++){
                int diff = nums[i] - nums[j];
                dp[i][diff+500] = max(2,1+dp[j][diff+500]);
                ans = max(ans , dp[i][diff+500]);
            }
        }
        return ans;
    }
};
