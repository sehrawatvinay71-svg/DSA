#include<bits/stdc++.h>
using namespace std;

class Solution {
public:
    int MOD = 1e9 + 7;
    int n, m;
    vector<string> arr;
    vector<vector<int>> dist;
    vector<vector<int>> no;

    bool isvalid(int i, int j) {
        return i >= 0 && i < n && j >= 0 && j < m && arr[i][j] != 'X';
    }

    vector<int> pathsWithMaxScore(vector<string>& board) {
        arr = board;
        n = arr.size();
        m = arr[0].size();

        dist = vector<vector<int>>(n, vector<int>(m, -1));
        no = vector<vector<int>>(n, vector<int>(m, 0));

        dist[n - 1][m - 1] = 0;
        no[n - 1][m - 1] = 1;

        for (int i = n - 1; i >= 0; i--) {
            for (int j = m - 1; j >= 0; j--) {

                if (arr[i][j] == 'X') continue;
                if (i == n - 1 && j == m - 1) continue;

                vector<pair<int,int>> neigh = {
                    {i + 1, j},
                    {i, j + 1},
                    {i + 1, j + 1}
                };

                int best = -1;
                int ways = 0;

                for (auto v : neigh) {
                    int x = v.first;
                    int y = v.second;

                    if (!isvalid(x, y)) continue;
                    if (dist[x][y] == -1) continue;

                    if (dist[x][y] > best) {
                        best = dist[x][y];
                        ways = no[x][y];
                    }
                    else if (dist[x][y] == best) {
                        ways += no[x][y];
                        ways %= MOD;
                    }
                }

                if (best == -1) continue;

                int add = 0;
                if (arr[i][j] >= '1' && arr[i][j] <= '9') {
                    add = arr[i][j] - '0';
                }

                dist[i][j] = best + add;
                no[i][j] = ways;
            }
        }

        if (dist[0][0] == -1) return {0, 0};

        return {dist[0][0], no[0][0]};
    }
};
