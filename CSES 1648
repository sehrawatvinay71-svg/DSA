#include<bits/stdc++.h>
using namespace std;

long long seg_tree[800400];
long long a[200100];

void build(int i,int l,int r){
    if(l==r){
        seg_tree[i] = a[l];
        return;
    }

    int mid = (l+r)/2;
    build(2*i,l,mid);
    build(2*i+1,mid+1,r);

    seg_tree[i] = seg_tree[2*i] + seg_tree[2*i+1];
}

void update(int i,int l,int r,int pos,long long x){
    if(l==r){
        a[pos] = x;
        seg_tree[i] = x;
        return;
    }

    int mid = (l+r)/2;

    if(pos<=mid){
        update(2*i,l,mid,pos,x);
    }else{
        update(2*i+1,mid+1,r,pos,x);
    }

    seg_tree[i] = seg_tree[2*i] + seg_tree[2*i+1];
}

long long query(int i,int l,int r,int lq,int rq){
    if(lq>r || l>rq) return 0;

    if(l>=lq && r<=rq){
        return seg_tree[i];
    }

    int mid = (l+r)/2;

    return query(2*i,l,mid,lq,rq) + query(2*i+1,mid+1,r,lq,rq);
}

int main(){
    ios::sync_with_stdio(false);
    cin.tie(NULL);

    int n,q;
    cin>>n>>q;

    for(int i=0;i<n;i++){
        cin>>a[i];
    }

    build(1,0,n-1);

    while(q--){
        int type;
        cin>>type;

        if(type==1){
            int k;
            long long u;
            cin>>k>>u;
            k--;
            update(1,0,n-1,k,u);
        }else{
            int l,r;
            cin>>l>>r;
            l--;
            r--;
            cout<<query(1,0,n-1,l,r)<<"\n";
        }
    }
}
