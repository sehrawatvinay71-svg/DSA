#include<bits/stdc++.h>
using namespace std;
#define int long long
int n,q;
int arr[200200];

struct node{
    int count;
    node(){
        count = 0;
    }
};

struct operation{
    char c;
    int a,b;
};

vector<int> values;
vector<operation> queries;
node seg_tree[8000800];

node make_node(int x){
    node ans;
    ans.count = x;
    return ans;
}

node merge(node a,node b){
    node ans;
    ans.count = a.count+b.count;
    return ans;
}

void build(int idx, int l,int r){
    if(l==r){
        seg_tree[idx] = make_node(0);
        return;
    }
    int mid = (l+r)/2;
    build(2*idx,l,mid);
    build(2*idx+1,mid+1,r);
    seg_tree[idx] = merge(seg_tree[2*idx],seg_tree[2*idx+1]);
}

int query(int idx,int l,int r,int lq,int rq){
    if(r<lq||rq<l){
        return 0;
    }
    if(l>=lq&&r<=rq){
        return seg_tree[idx].count;
    }
    int mid = (l+r)/2;
    return (query(2*idx,l,mid,lq,rq)+query(2*idx+1,mid+1,r,lq,rq));
}

void update(int idx,int l,int r,int pos,int val){
    if(l==r){
        seg_tree[idx].count += val;
        return;
    }
    int mid = (l+r)/2;
    if(pos<=mid){
        update(2*idx,l,mid,pos,val);
    }else{
        update(2*idx+1,mid+1,r,pos,val);
    }
    seg_tree[idx] = merge(seg_tree[2*idx],seg_tree[2*idx+1]);
}

int getIndex(int salary){
    return lower_bound(values.begin(),values.end(),salary) - values.begin();
}

signed main(){
    cin>>n>>q;
    for(int i=1;i<=n;i++){
        cin>>arr[i];
        values.push_back(arr[i]);
    }
    queries.resize(q);
    for(int i=0;i<q;i++){
        cin>>queries[i].c>>queries[i].a>>queries[i].b;
        if(queries[i].c=='!'){
            values.push_back(queries[i].b);
        }
    }

    sort(values.begin(),values.end());

    values.erase(unique(values.begin(),values.end()),values.end());

    int m = values.size();



    build(1,0,m-1);
    for(int i=1;i<=n;i++){
        int pos = getIndex(arr[i]);
        update(1,0,m-1,pos,1);
    }
    // for(int i=1;i<4*n;i++){
    //     cout<<"i : "<<i<<" open : "<<seg_tree[i].open<<" close : "<<seg_tree[i].close<<" all : "<<seg_tree[i].all<<endl;
    // }
     for(int i=0;i<q;i++){
        char c = queries[i].c;
        int a = queries[i].a;
        int b = queries[i].b;

        if(c=='!'){
            // Old salary ka count -1
            int oldPos = getIndex(arr[a]);
            update(1,0,m-1,oldPos,-1);

            arr[a] = b;

            // New salary ka count +1
            int newPos = getIndex(arr[a]);
            update(1,0,m-1,newPos,1);
        }else{
            // First compressed salary >= a
            int left = lower_bound(
                values.begin(),
                values.end(),
                a
            )-values.begin();

            // Last compressed salary <= b
            int right = upper_bound(
                values.begin(),
                values.end(),
                b
            )-values.begin()-1;

            if(left>right){
                cout<<0<<'\n';
            }else{
                cout<<query(1,0,m-1,left,right)<<'\n';
            }
        }
    }
}
