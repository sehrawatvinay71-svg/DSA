#include<bits/stdc++.h>
using namespace std;
string s;
int n;
vector<int> mark;
int dp[1000001];

int main() {
    cin>>s;
    n = s.length();
    mark.resize(n);
    stack<int> st;

    for(int i=0;i<n;i++){
        if(s[i]=='('){
            st.push(i);
        }else{
            if(!st.empty()){
                int match = st.top();
                st.pop();
                mark[match] = 1;
                mark[i] = 1;
            }
        }
    }
    //cout<<mark[n-1]<<endl;
    int ans = 0;
    int count  = 0;
    memset(dp,0,sizeof(dp));

    for(int i=0;i<n;i++){
        if(mark[i]==1){
            dp[i]=1;
        }
    }

    for(int i=1;i<n;i++){
        if(mark[i]!=0){
            dp[i] += dp[i-1];
        }
    }
    // for(int i=0;i<n;i++){
    //     cout<<dp[i]<<" ";
    // }

    for(int i=0;i<n;i++){
        if(ans<dp[i]){
            ans = max(ans,dp[i]);
            count =1;
        }else if(ans==dp[i]){
            count++;
        }
    }
    if(ans!=0)cout<<ans<<" "<<count<<" "<<endl;
    else cout<<0<<" "<<1<<endl;

}
