#include<bits/stdc++.h>
using namespace std;
int n,q;
int arr[100100];

struct node{
    int odd,even;
    node(){
        odd = 0;
        even = 0;
    }
};
node seg_tree[400400];

node merge(node a,node b){
    node ans;
    ans.odd = a.odd + b.odd;
    ans.even = a.even + b.even;
    return ans;
}

void build(int idx,int l,int r){
    if(l==r){
        if(arr[l]%2==0){
            seg_tree[idx].even+=1;
        }else{
            seg_tree[idx].odd+=1;
        }
        return;   
    }
    int mid = (l+r)/2;
    build(2*idx,l,mid);
    build(2*idx+1,mid+1,r);
    seg_tree[idx] = merge(seg_tree[2*idx],seg_tree[2*idx+1]);
}

void update(int idx,int l,int r,int pos,int val){
    if(l==r){
        if(val%2==0){
            if(seg_tree[idx].odd==1){
                seg_tree[idx].even+=1;
                seg_tree[idx].odd-=1;
                return;
            }
        }else{
            if(seg_tree[idx].even==1){
                seg_tree[idx].odd+=1;
                seg_tree[idx].even-=1;
                return;
            }
        }
        arr[pos] = val;
        return;
    }
    int mid = (l+r)/2;
    if(pos<=mid){
        update(2*idx,l,mid,pos,val);
    }else{
        update(2*idx+1,mid+1,r,pos,val);
    }
    seg_tree[idx] = merge(seg_tree[2*idx],seg_tree[2*idx+1]);
}

int queryeven(int idx,int l,int r,int lq,int rq){
    if(l>rq||lq>r){
        return 0;
    }
    if(l>=lq&&r<=rq){
        return seg_tree[idx].even;
    }
    int mid = (l+r)/2;

    return queryeven(2*idx,l,mid,lq,rq) + queryeven(2*idx+1,mid+1,r,lq,rq);
}

int queryodd(int idx,int l,int r,int lq,int rq){
    if(l>rq||lq>r){
        return 0;
    }
    if(l>=lq&&r<=rq){
        return seg_tree[idx].odd;
    }
    int mid = (l+r)/2;

    return queryodd(2*idx,l,mid,lq,rq) + queryodd(2*idx+1,mid+1,r,lq,rq);
}



signed main(){
    cin>>n;
    for(int i=1;i<=n;i++){
        cin>>arr[i];
    }
    cin>>q;
    build(1,1,n);
    while(q--){
        int x,a,b;
        cin>>x>>a>>b;
        if(x==0){
            update(1,1,n,a,b);
        }else if(x==1){
            cout<<queryeven(1,1,n,a,b)<<endl;
        }else{
            cout<<queryeven(1,1,n,a,b)<<endl;
        }
    }
}
