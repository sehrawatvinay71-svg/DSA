#include<bits/stdc++.h>
using namespace std;
#define int long long
int n,q;

int arr[200200];

struct node{
    int sum;
    bool islazy;
    int lazyadd;
    int lazystart;
    int lazydiff;
    node(){
        sum = 0;
        islazy = false;
        lazystart = 0;
        lazydiff = 0;
    }
};

node seg_tree[800800];

node merge(node a,node b){
    node ans;
    ans.sum = a.sum+b.sum;
    return ans;
}

void push(int idx, int l,int r){
    if(l==r) return;
    if(!seg_tree[idx].islazy) return;

    int mid = (l+r)/2;

    int left = 2*idx;
    int right = 2*idx+1;

    int lenleft = mid-l+1;
    int lenright = r-mid;

    int start = seg_tree[idx].lazystart;
    int diff = seg_tree[idx].lazydiff;
    int rightstart = start+ lenleft*diff;

    seg_tree[left].sum += lenleft*start +(lenleft *(lenleft-1)/2)*diff;
    seg_tree[left].islazy = true;
    seg_tree[left].lazystart += start;
    seg_tree[left].lazydiff +=diff;

    seg_tree[right].sum += lenright*rightstart +(lenright *(lenright-1)/2)*diff;
    seg_tree[right].islazy = true;
    seg_tree[right].lazystart += rightstart;
    seg_tree[right].lazydiff +=diff;

    seg_tree[idx].islazy = false;
    seg_tree[idx].lazystart = 0;
    seg_tree[idx].lazydiff = 0;
}

void build(int idx,int l,int r){
    if(l==r){
        seg_tree[idx].sum = arr[l];
        return;
    }
    int mid = (l+r)/2;
    build(2*idx,l,mid);
    build(2*idx+1,mid+1,r);
    seg_tree[idx] = merge(seg_tree[2*idx],seg_tree[2*idx+1]);
}


void update(int idx,int l,int r,int lq,int rq){
    if(l>rq||lq>r){
        return;
    }
    if(l>=lq&&r<=rq){
        int len = r-l+1;
        int start = l-lq+1;
        int diff = 1;

        seg_tree[idx].sum += len*start + ((len * (len - 1))/2)*diff;

        seg_tree[idx].islazy = true;
        seg_tree[idx].lazystart +=start;
        seg_tree[idx].lazydiff +=diff;
        return;
    }
    push(idx,l,r);
    int mid = (l+r)/2;
    update(2*idx,l,mid,lq,rq);
    update(2*idx+1,mid+1,r,lq,rq);

    seg_tree[idx] = merge(seg_tree[2*idx],seg_tree[2*idx+1]);
}

node query(int idx,int l,int r,int lq, int rq){
    if(lq>r||l>rq){
        return node();
    }
    if(l>=lq&&r<=rq){
        return seg_tree[idx];
    }
    push(idx,l,r);
    int mid = (l+r)/2;
    return merge(query(2*idx,l,mid,lq,rq),query(2*idx+1,mid+1,r,lq,rq));

}

signed main(){
    cin>>n>>q;
    for(int i=1;i<=n;i++){
        cin>>arr[i];
    }
    build(1,1,n);
    for(int i=0;i<q;i++){
        int a;
        cin>>a;
        if(a==1){
            int x,y;
            cin>>x>>y;
            update(1,1,n,x,y);
        }else{
            int x,y;
            cin>>x>>y;
            node ans = query(1,1,n,x,y);
            cout<<ans.sum<<endl;
        }
    }
}
