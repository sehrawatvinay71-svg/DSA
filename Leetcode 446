class Solution {
public:
    int numberOfArithmeticSlices(vector<int>& nums) {
        int n = nums.size();
        vector<unordered_map<long long,long long>> dp(n);
        long long ans = 0;
        for(int i=0;i<n;i++){
            for(int j=0;j<i;j++){
                long long diff = (long long)nums[i] - nums[j];
                long long prev = dp[j][diff];

                ans+=prev;

                dp[i][diff] += prev+1;    
            }
        }
        return ans;
    }
};
