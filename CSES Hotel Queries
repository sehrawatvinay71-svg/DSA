#include<bits/stdc++.h>
using namespace std;
#define int long long

struct node{
    int max_no;
    node(){
        max_no=0;
    }
};
int n,q;
vector<int> arr;
node segtree[800800];


node merge(node a,node b){
    node ans;
    ans.max_no = max(a.max_no,b.max_no);
    return ans;
}

void build(int idx,int l,int r){
    if(l==r){
        segtree[idx].max_no = arr[l];
        return;
    }
    int mid = (l+r)/2;
    build(2*idx,l,mid);
    build(2*idx+1,mid+1,r);
    segtree[idx] = merge(segtree[2*idx],segtree[2*idx+1]);
}

void update(int idx,int l,int r,int pos,int val){
    if(pos<l||pos>r){
        return;
    }
    if(l==r){
        segtree[idx].max_no -=val;
        return;
    }
    int mid = (l+r)/2;
    update(2*idx,l,mid,pos,val);
    update(2*idx+1,mid+1,r,pos,val);

    segtree[idx] = merge(segtree[2*idx],segtree[2*idx+1]);
}

int query(int idx,int l,int r,int k){
    if(segtree[idx].max_no<k) return 0;
    if(l==r){
        return l;
    }
    int mid = (l+r)/2;
    if(k<=segtree[2*idx].max_no){
        return query(2*idx,l,mid,k);
    }else{
        return query(2*idx+1,mid+1,r,k);
    }
}


signed main(){
    cin>>n>>q;
    arr.resize(n+1);
    for(int i=1;i<=n;i++){
        cin>>arr[i];       
    }
    build(1,1,n);
    // update(1,0,n-1,1,1);
    // update(1,0,n-1,4,-1);
    // for(int i=1;i<4*n;i++){
    //     cout<<i<<" "<<segtree[i].sum<<endl;
    // }
    while(q--){
        int x;
        cin>>x;
        int idx = query(1,1,n,x);
        cout<<idx<<" ";
        if(idx!=0){
            update(1,1,n,idx,x);
        }
    }
}
